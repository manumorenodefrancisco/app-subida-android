<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_bg"
    android:scrollbars="none"
    android:id="@+id/main"
    android:fillViewport="true"
    android:fitsSystemWindows="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="20dp"
        android:paddingBottom="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="21dp"
            android:background="@drawable/bg_neon_panel"
            android:foreground="@drawable/neon_panel">

            <TextView
                android:id="@+id/tvHeaderApp"
                android:layout_width="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/orbitron_medium"
                android:text="HOLA DE NUEVO"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/contNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.5dp"
                android:orientation="horizontal"


                app:layout_constraintTop_toBottomOf="@id/tvHeaderApp"
                app:layout_constraintStart_toStartOf="parent">
                <!--
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/orbitron_semibold"
                    android:text="USER "
                    android:textColor="@color/white"
                    android:textSize="20sp" />-->

                <TextView
                    android:id="@+id/user_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/orbitron_semibold"
                    android:shadowColor="#AA00D4FF"
                    android:shadowRadius="15"
                    android:text="USER"
                    android:textColor="@color/azul_brillante"
                    android:textSize="24sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/neon_square_border"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_nivel_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/orbitron_bold"
                    android:text="42"
                    android:textColor="@color/azul_brillante"
                    android:textSize="22sp"
                    android:shadowColor="#00E5FF"
                    android:shadowRadius="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/orbitron_medium"
                    android:text="NIVEL"
                    android:textColor="#46719E"
                    android:textSize="9sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/contNombre"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="4.5dp">
                <TextView
                    android:id="@+id/tvRangoSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/rajdhani_semibold"
                    android:text="«El Que Supera Límites»"
                    android:textColor="@color/azul_neon"
                    android:textSize="14sp"
                    android:layout_weight="5"
                    android:layout_gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/contNombre"
                    app:layout_constraintStart_toStartOf="parent" />
                <TextView
                    android:id="@+id/tv_dias_racha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/orbitron_medium"
                    android:textColor="@color/white"
                    android:textAlignment="textEnd"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical|end"
                    android:text="Días de racha: 10"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvRangoSub"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </LinearLayout>

