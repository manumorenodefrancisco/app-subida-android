<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/negriazul_podom2" />
            <stroke
                android:width="1dp"
                android:color="@color/azul_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- Progress -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient
                    android:startColor="@color/azul_border"
                    android:centerColor="@color/azul_neon"
                    android:endColor="@color/azul_brillante"
                    android:angle="90" />
                <corners android:radius="4dp" />
            </shape>
        </clip>
    </item>
</layer-list>
