<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="6dp" android:color="#5500d4ff" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <stroke android:width="3dp" android:color="#3300d4ff" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <stroke android:width="1dp" android:color="@color/azul_brillante" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
