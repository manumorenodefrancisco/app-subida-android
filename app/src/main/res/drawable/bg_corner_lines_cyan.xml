<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Esquina superior izquierda -->
    <item android:gravity="top|left">
        <shape android:shape="rectangle">
            <size android:width="14dp" android:height="14dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="@color/azul_brillante" />
        </shape>
    </item>
    
    <!-- Esquina superior derecha -->
    <item android:gravity="top|right">
        <shape android:shape="rectangle">
            <size android:width="14dp" android:height="14dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="@color/azul_brillante" />
        </shape>
    </item>
    
    <!-- Esquina inferior izquierda -->
    <item android:gravity="bottom|left">
        <shape android:shape="rectangle">
            <size android:width="14dp" android:height="14dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="@color/azul_brillante" />
        </shape>
    </item>
    
    <!-- Esquina inferior derecha -->
    <item android:gravity="bottom|right">
        <shape android:shape="rectangle">
            <size android:width="14dp" android:height="14dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="@color/azul_brillante" />
        </shape>
    </item>
</layer-list>
