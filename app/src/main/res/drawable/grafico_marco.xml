<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo oscuro del gráfico -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#020818" />
        </shape>
    </item>

    <!-- Línea superior de separación -->
    <item android:bottom="142dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/azul_border" />
        </shape>
    </item>

    <!-- Esquina superior izquierda (L) -->
    <item android:right="150dp" android:bottom="155dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="@color/azul_brillante" />
        </shape>
    </item>
    <item android:left="5dp" android:top="5dp" android:right="155dp" android:bottom="160dp">
         <shape android:shape="rectangle">
            <solid android:color="#020818" />
        </shape>
    </item>

    <!-- Esquina inferior derecha (L invertida) -->
    <item android:left="150dp" android:top="155dp">
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="@color/azul_brillante" />
        </shape>
    </item>
    <item android:left="155dp" android:top="160dp" android:right="5dp" android:bottom="5dp">
         <shape android:shape="rectangle">
            <solid android:color="#020818" />
        </shape>
    </item>
</layer-list>