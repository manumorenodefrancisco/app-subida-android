<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro_bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true">

                <TextView
                    android:id="@+id/tvTablonTareas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TABLÓN DE TAREAS"
                    android:fontFamily="@font/orbitron_bold"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:letterSpacing="0.10" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REINICIO EN ◈ 08:42:15 ◈ PENALIZACIÓN ACTIVA"
                    android:fontFamily="@font/orbitron_medium"
                    android:textSize="8sp"
                    android:textColor="@color/gris_azulado" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentEnd="true"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XP GANADA HOY"
                    android:fontFamily="@font/orbitron_medium"
                    android:textSize="8sp"
                    android:textColor="@color/gris_azulado" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+120"
                    android:fontFamily="@font/orbitron_bold"
                    android:textSize="18sp"
                    android:textColor="@color/naranja_principal" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/neon_panel">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROGRESO DIARIO"
                    android:fontFamily="@font/orbitron_medium"
                    android:textSize="8sp"
                    android:textColor="@color/gris_azulado" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1/4 COMPLETADAS"
                    android:fontFamily="@font/orbitron_bold"
                    android:textSize="8sp"
                    android:textColor="@color/azul_brillante"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progressDiario"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="4"
                android:progress="1"
                android:progressDrawable="@drawable/progress_bar_neon" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/gris_azulado" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Tiempo restante: 08:42:15"
                        android:fontFamily="@font/rajdhani_medium"
                        android:textSize="11sp"
                        android:textColor="@color/gris_azulado" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/warning" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Penalización"
                        android:fontFamily="@font/rajdhani_medium"
                        android:textSize="11sp"
                        android:textColor="@color/warning" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TODAS"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/filter_tab_active"
                android:textColor="@color/azul_brillante"
                android:fontFamily="@font/orbitron_bold"
                android:textSize="9sp"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DIARIAS"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/filter_tab_inactive"
                android:textColor="@color/gris_azulado"
                android:fontFamily="@font/orbitron_bold"
                android:textSize="9sp"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SECUNDARIAS"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:background="@drawable/filter_tab_inactive"
                android:textColor="@color/gris_azulado"
                android:fontFamily="@font/orbitron_bold"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- TARJETA DE TAREA EJEMPLO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/task_card">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:background="@drawable/task_header">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_book"
                        app:tint="@color/azul_neon"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACADEMIA"
                        android:textColor="@color/azul_neon"
                        android:fontFamily="@font/orbitron_bold"
                        android:textSize="9sp"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="DIARIA"
                    android:textColor="@color/azul_brillante"
                    android:fontFamily="@font/orbitron_bold"
                    android:textSize="7sp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:background="@drawable/badge_diaria"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Completar módulo de Android Studio"
                    android:textColor="@color/texto_misiones"
                    android:fontFamily="@font/rajdhani_bold"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Implementar el RecyclerView de tareas con su adaptador personalizado."
                    android:textColor="@color/gris_azulado"
                    android:fontFamily="@font/rajdhani_medium"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+350 XP"
                        android:textColor="@color/naranja_principal"
                        android:fontFamily="@font/orbitron_bold"
                        android:textSize="10sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btnAceptarTarea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ ACEPTAR TAREA"
                        android:background="@drawable/btn_aceptar_tarea"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="7dp"
                        android:textColor="@color/azul_brillante"
                        android:fontFamily="@font/orbitron_bold"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="14dp"
            android:background="@drawable/btn_dashed_border"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_plus"
                app:tint="@color/gris_azulado" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="REGISTRAR NUEVA TAREA"
                android:fontFamily="@font/orbitron_bold"
                android:textSize="10sp"
                android:textColor="@color/gris_azulado" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>