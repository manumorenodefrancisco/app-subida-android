<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_card_panel_azul">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Has completado la tarea?"
        android:textColor="@color/azul_brillante"
        android:fontFamily="@font/orbitron_black"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/azul_border"
        android:alpha="0.4"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_tarea_dialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre de la tarea"
        android:textAlignment="textStart"
        android:layout_marginStart="47dp"
        android:textColor="@color/texto_misiones"
        android:fontFamily="@font/rajdhani_medium"
        android:textSize="14sp"
        android:gravity="center|start"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancelar"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NO"
            android:textColor="@color/gris_azulado"
            android:fontFamily="@font/orbitron_bold"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp" />

        <Button
            android:id="@+id/btn_completar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SI"
            android:textColor="@color/negro_bg"
            android:fontFamily="@font/orbitron_black"
            android:textSize="12sp"
            android:backgroundTint="@color/success"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
