<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_mission_item">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_icono_tarea"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_sword"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_tarea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titulo de tarea"
                android:textColor="@color/texto_misiones"
                android:textSize="14sp"
                android:fontFamily="@font/rajdhani_semibold" />

            <TextView
                android:id="@+id/tv_descripcion_tarea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textColor="#57718E"
                android:textSize="12sp"
                android:fontFamily="@font/rajdhani_semibold"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_fecha_tarea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vence: dd/mm/yyyy"
                android:textColor="@color/azul_neon"
                android:textSize="11sp"
                android:fontFamily="@font/rajdhani_semibold"
                android:layout_marginTop="4dp" />


        </LinearLayout>

        <TextView
            android:id="@+id/tv_xp_tarea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0 XP"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:fontFamily="@font/rajdhani_semibold"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

</LinearLayout>
